diff --git a/lib/generation/json-repair.ts b/lib/generation/json-repair.ts
index a754c00..4572586 100644
--- a/lib/generation/json-repair.ts
+++ b/lib/generation/json-repair.ts
@@ -8,8 +8,9 @@ const log = createLogger('Generation');

 function repairQuotedPropertyFragments(jsonStr: string): string {
   return jsonStr.replace(
-    /([,{]\s*)"([A-Za-z_][A-Za-z0-9_]*)\s*:\s*(true|false|null|[+-]?\d+(?:\.\d+)?)"(?=\s*[,}])/g,
-    (_match, prefix, key, value) => `${prefix}"${key}": ${value}`,
+    /([,{]\s*)"([A-Za-z_][A-Za-z0-9_]*)\s*:\s*(true|false|null|[+-]?(?:\d+(?:\.\d+)?|\.\d+))"(?=\s*[,}])/g,
+    (_match, prefix, key, value) =>
+      `${prefix}"${key}": ${value.replace(/^([+-]?)\./, '$10.')}`,
   );
 }

diff --git a/tests/generation/json-repair.test.ts b/tests/generation/json-repair.test.ts
index a401982..adc79b7 100644
--- a/tests/generation/json-repair.test.ts
+++ b/tests/generation/json-repair.test.ts
@@ -54,4 +54,26 @@ describe('json-repair targeted fixes', () => {
     expect(parsed?.elements[0]?.height).toBe(58);
     expect(parsed?.elements[0]?.content).toBe('<p>literal text: height: 58</p>');
   });
+
+  it('repairs leading-decimal numeric property fragments without touching valid strings', () => {
+    const raw = `{
+  "elements": [
+    {
+      "id": "shape_1",
+      "opacity: .5",
+      "x: -.25",
+      "content": "literal opacity: .5 and x: -.25"
+    }
+  ]
+}`;
+
+    const parsed = parseJsonResponse<{
+      elements: Array<{ opacity: number; x: number; content: string }>;
+    }>(raw);
+
+    expect(parsed).not.toBeNull();
+    expect(parsed?.elements[0]?.opacity).toBe(0.5);
+    expect(parsed?.elements[0]?.x).toBe(-0.25);
+    expect(parsed?.elements[0]?.content).toBe('literal opacity: .5 and x: -.25');
+  });
 });
